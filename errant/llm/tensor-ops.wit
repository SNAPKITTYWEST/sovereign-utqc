// ════════════════════════════════════════════════════════════════
// ERRANT-GGML WIT CONTRACT — Sovereign Tensor Operations
// 
// WASM loads the kernel.
// ERRANT owns the capability.
// Prolog proves the tensor flow.
// WORM seals the artifact.
//
// The model runs only when the proof permits the memory to move.
//
// Ahmad Ali Parr · SNAPKITTYWEST · ERRANT-GENESIS-001
// ════════════════════════════════════════════════════════════════

package snapkitty:errant-ggml@0.1.0;

/// ════════════════════════════════════════════════════════════════
/// TENSOR OPERATIONS — Linear capability interface
/// ════════════════════════════════════════════════════════════════

interface tensor-ops {

    /// ════════════════════════════════════════════════════════════════
    /// TENSOR — Linear resource (must be consumed exactly once)
    /// ════════════════════════════════════════════════════════════════

    resource tensor {
        /// Shape of the tensor (e.g., [3, 512, 4096])
        shape: func() -> list<u32>;
        
        /// Data type (e.g., "f32", "f16", "fp8", "q4_0")
        dtype: func() -> string;
        
        /// WORM seal hash (computed on allocation)
        seal: func() -> string;
        
        /// Number of elements
        size: func() -> u64;
        
        /// Byte offset in WASM memory
        offset: func() -> u64;
    }

    /// ════════════════════════════════════════════════════════════════
    /// KERNEL-CAP — Linear capability for GPU operations
    /// Must be consumed exactly once per operation
    /// ════════════════════════════════════════════════════════════════

    resource kernel-cap {
        /// Kernel name (e.g., "matmul_fp16", "flash_attn_v2")
        name: func() -> string;
        
        /// Compute capability (e.g., "sm_80", "sm_89")
        compute-cap: func() -> string;
        
        /// Memory requirement in bytes
        memory-req: func() -> u64;
        
        /// WORM seal of the kernel binary
        kernel-seal: func() -> string;
    }

    /// ════════════════════════════════════════════════════════════════
    /// SEAL — WORM artifact for tensor operations
    /// ════════════════════════════════════════════════════════════════

    record seal {
        /// SHA-256 hash of the operation
        hash: string,
        
        /// Number of compute steps
        steps: u64,
        
        /// WORM artifact path
        artifact: string,
        
        /// Timestamp (ISO 8601)
        timestamp: string,
        
        /// Operation signature
        signature: string,
    }

    /// ════════════════════════════════════════════════════════════════
    /// VERDICT — Type-safe result (like Haskell's Either)
    /// ════════════════════════════════════════════════════════════════

    variant verdict {
        /// Operation succeeded, artifact sealed
        evidence(seal),
        
        /// Operation failed, reason recorded
        silence(string),
    }

    /// ════════════════════════════════════════════════════════════════
    /// TENSOR OPERATIONS — Linear capability required
    /// Each operation consumes its inputs (no aliasing)
    /// ════════════════════════════════════════════════════════════════

    /// Allocate a tensor (linear resource created)
    alloc: func(
        shape: list<u32>,
        dtype: string
    ) -> tensor;
    
    /// Free a tensor (linear resource consumed)
    free: func(
        t: tensor
    );
    
    /// Matrix multiplication (consumes cap + both tensors)
    matmul: func(
        cap: kernel-cap,
        a: tensor,
        b: tensor
    ) -> result<tensor, string>;
    
    /// Flash attention v2 (consumes cap + q, k, v tensors)
    flash-attn: func(
        cap: kernel-cap,
        q: tensor,
        k: tensor,
        v: tensor
    ) -> result<tensor, string>;
    
    /// Quantize to FP8 (consumes cap + input tensor)
    quantize-fp8: func(
        cap: kernel-cap,
        input: tensor
    ) -> result<tensor, string>;
    
    /// Quantize to INT4 (consumes cap + input tensor)
    quantize-int4: func(
        cap: kernel-cap,
        input: tensor
    ) -> result<tensor, string>;
    
    /// RMS normalization (consumes cap + input tensor)
    rms-norm: func(
        cap: kernel-cap,
        input: tensor,
        weight: tensor
    ) -> result<tensor, string>;
    
    /// Rotary position embedding (consumes cap + input tensor)
    rope: func(
        cap: kernel-cap,
        input: tensor,
        freqs: tensor
    ) -> result<tensor, string>;
    
    /// SiLU activation (consumes cap + input tensor)
    silu: func(
        cap: kernel-cap,
        input: tensor
    ) -> result<tensor, string>;
    
    /// Softmax (consumes cap + input tensor)
    softmax: func(
        cap: kernel-cap,
        input: tensor
    ) -> result<tensor, string>;
    
    /// Seal a tensor (produces WORM artifact)
    seal-tensor: func(
        input: tensor
    ) -> verdict;
    
    /// Verify a tensor seal
    verify-seal: func(
        input: tensor,
        expected-seal: seal
    ) -> bool;
}

/// ════════════════════════════════════════════════════════════════
/// MoE ROUTING — Mixture of Experts with linear capabilities
/// ════════════════════════════════════════════════════════════════

interface moe-ops {
    /// ════════════════════════════════════════════════════════════════
    /// EXPERT — Linear capability for a single expert
    /// ════════════════════════════════════════════════════════════════

    resource expert {
        /// Expert ID
        id: func() -> u32;
        
        /// Expert name (e.g., "reasoning", "code", "math")
        name: func() -> string;
        
        /// WORM seal of expert weights
        weights-seal: func() -> string;
        
        /// Activation count (must be consumed)
        activations: func() -> u64;
    }

    /// ════════════════════════════════════════════════════════════════
    /// ROUTER — Linear capability for routing decisions
    /// ════════════════════════════════════════════════════════════════

    resource router {
        /// Router name (e.g., "top-k", "expert-choice")
        name: func() -> string;
        
        /// Number of experts
        num-experts: func() -> u32;
        
        /// Top-K value
        top-k: func() -> u32;
    }

    /// ════════════════════════════════════════════════════════════════
    /// MoE OPERATIONS
    /// ════════════════════════════════════════════════════════════════

    /// Route input to experts (consumes router + input tensor)
    route: func(
        router: router,
        input: tensor,
        experts: list<expert>
    ) -> result<list<expert>, string>;
    
    /// Execute expert (consumes expert + input tensor)
    execute-expert: func(
        expert: expert,
        input: tensor,
        cap: kernel-cap
    ) -> result<tensor, string>;
    
    /// Combine expert outputs (consumes all expert outputs)
    combine: func(
        outputs: list<tensor>,
        weights: tensor
    ) -> result<tensor, string>;
    
    /// Seal MoE operation (produces WORM artifact)
    seal-moe: func(
        router: router,
        input: tensor,
        outputs: list<tensor>
    ) -> verdict;
}

/// ════════════════════════════════════════════════════════════════
/// SOVEREIGN MODEL — Complete LLM with ERRANT enforcement
/// ════════════════════════════════════════════════════════════════

interface sovereign-model {
    /// ════════════════════════════════════════════════════════════════
    /// MODEL — Linear capability for the complete model
    /// ════════════════════════════════════════════════════════════════

    resource model {
        /// Model name
        name: func() -> string;
        
        /// Model version
        version: func() -> string;
        
        /// Number of layers
        num-layers: func() -> u32;
        
        /// Hidden dimension
        hidden-dim: func() -> u32;
        
        /// Number of experts (MoE)
        num-experts: func() -> u32;
        
        /// WORM seal of model weights
        weights-seal: func() -> string;
    }

    /// ════════════════════════════════════════════════════════════════
    /// SOVEREIGN OPERATIONS
    /// ════════════════════════════════════════════════════════════════

    /// Load model (consumes WASM module, produces model capability)
    load-model: func(
        wasm-path: string,
        weights-path: string
    ) -> result<model, string>;
    
    /// Forward pass (consumes model + input, produces output)
    forward: func(
        model: model,
        input: tensor,
        cap: kernel-cap
    ) -> result<tensor, verdict>;
    
    /// Generate text (consumes model + prompt, produces completion)
    generate: func(
        model: model,
        prompt: tensor,
        cap: kernel-cap,
        max-tokens: u32
    ) -> result<tensor, verdict>;
    
    /// Seal model (produces WORM artifact)
    seal-model: func(
        model: model
    ) -> verdict;
    
    /// Verify model integrity
    verify-model: func(
        model: model,
        expected-seal: seal
    ) -> bool;
}

/// ════════════════════════════════════════════════════════════════
/// WORM CHAIN — Append-only audit trail
/// ════════════════════════════════════════════════════════════════

interface worm-chain {
    /// Append event to WORM chain
    append: func(
        label: string,
        payload: string,
        prev-seal: string
    ) -> seal;
    
    /// Verify WORM chain integrity
    verify: func() -> bool;
    
    /// Get chain length
    length: func() -> u64;
    
    /// Get last seal
    last-seal: func() -> string;
}
