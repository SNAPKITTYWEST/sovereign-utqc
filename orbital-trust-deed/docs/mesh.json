{
  "schema": "snapkitty.mesh.node.v1",
  "id": "orbital-trust-deed",
  "name": "Orbital Trust Deed",
  "lane": "prove",
  "status": "wip",
  "authority": "Trust Deed verification for public orbital telemetry",
  "repoPath": "orbital-trust-deed",
  "runtime": {
    "language": "Elixir",
    "framework": "Phoenix LiveView",
    "frontend": "GitHub Pages + CesiumJS preview"
  },
  "sources": [
    {
      "id": "celes-trak",
      "name": "CelesTrak",
      "type": "TLE",
      "apiKeyRequired": false,
      "module": "OrbitalTrustDeed.Sources.CelesTrak"
    },
    {
      "id": "nasa-gibs",
      "name": "NASA GIBS",
      "type": "WMTS imagery",
      "apiKeyRequired": false,
      "module": "OrbitalTrustDeed.Sources.NasaGibs"
    },
    {
      "id": "noaa-goes",
      "name": "NOAA GOES",
      "type": "ABI imagery",
      "apiKeyRequired": false,
      "module": "OrbitalTrustDeed.Sources.NoaaGoes"
    }
  ],
  "verificationGates": [
    "source",
    "schema",
    "timestamp",
    "freshness"
  ],
  "worm": {
    "module": "OrbitalTrustDeed.Worm.Chain",
    "appendOnly": true,
    "hash": "SHA-256"
  },
  "meshEvents": [
    "kitty.orbital.telemetry.received",
    "kitty.orbital.deed.verified",
    "kitty.orbital.worm.sealed",
    "kitty.mesh.agent.action.allowed",
    "kitty.mesh.agent.action.blocked"
  ],
  "agentBoundary": {
    "allowedAfterVerifiedDeed": true,
    "blockedIfStale": true,
    "blockedIfUntrustedSource": true,
    "blockedIfMissingWormSeal": true
  },
  "axioms": [
    "ZERO_TRUST_ALWAYS",
    "SIGN_BEFORE_STORE",
    "WORM_SEALED_DECISIONS",
    "DOMAIN_SOVEREIGNTY"
  ]
}
